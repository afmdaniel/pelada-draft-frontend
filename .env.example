# URL base da API — embutida no bundle JavaScript em build time (NEXT_PUBLIC_*)
# Dev local (npm run dev):     http://localhost:3000
# Docker local:                http://host.docker.internal:3000  (via build arg manual)
# Produção:                    https://api.pelada-draft.com.br
#
# EM PRODUÇÃO: não use este arquivo. Configure NEXT_PUBLIC_API_URL como
# GitHub Actions secret (Settings → Secrets and variables → Actions).
# O CI/CD injeta o valor via --build-arg durante o docker build.
NEXT_PUBLIC_API_URL=http://localhost:3000
