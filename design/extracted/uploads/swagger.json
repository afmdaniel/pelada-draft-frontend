  "info": {
    "title": "API de Peladas",
    "description": "Documentação completa da API de gerenciamento de peladas, jogadores e sorteio equilibrado de times.",
    "version": "1.0",
    "contact": {
      
    }
  },
  "tags": [
    {
      "name": "Autenticação",
      "description": "Rotas de login, cadastro e sessão"
    },
    {
      "name": "Peladas",
      "description": "Gerenciamento dos grupos de pelada"
    },
    {
      "name": "Jogadores",
      "description": "Gerenciamento dos jogadores dentro das peladas"
    },
    {
      "name": "Sorteio",
      "description": "Gerenciamento de sorteio de times dentro da pelada"
    },
    {
      "name": "Permissões",
      "description": "Gerenciamento de permissões de usuários dentro da pelada"
    }
  ],
  "servers": [
    
  ],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "refresh_token"
      }
    },
    "schemas": {
      "RegisterUserBody": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "E-mail do usuário.",
            "example": "usuario@email.com"
          },
          "username": {
            "type": "string",
            "description": "Username do usuário.",
            "example": "usuario123",
            "minLength": 3,
            "maxLength": 20
          },
          "password": {
            "type": "string",
            "description": "Senha com no mínimo 6 caracteres.",
            "example": "senhaForte123",
            "minLength": 6
          },
          "passwordConfirmation": {
            "type": "string",
            "description": "Confirmação da senha. Deve ser idêntica ao campo password.",
            "example": "senhaForte123"
          }
        },
        "required": [
          "email",
          "username",
          "password",
          "passwordConfirmation"
        ]
      },
      "RegisterResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Usuário registrado com sucesso."
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "AuthenticateBody": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "E-mail válido ou username do usuário.",
            "example": "usuario123"
          },
          "password": {
            "type": "string",
            "description": "Senha do usuário.",
            "example": "senhaForte123"
          }
        },
        "required": [
          "identifier",
          "password"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Login realizado com sucesso."
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "RefreshResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Token atualizado com sucesso."
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "ChangePasswordBody": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "description": "Senha atual do usuário.",
            "example": "senhaForte123"
          },
          "newPassword": {
            "type": "string",
            "description": "Senha com no mínimo 6 caracteres",
            "example": "senhaForte456",
            "minLength": 6
          },
          "newPasswordConfirmation": {
            "type": "string",
            "description": "Confirmação da senha. Deve ser idêntica ao campo password.",
            "example": "senhaForte456"
          }
        },
        "required": [
          "currentPassword",
          "newPassword",
          "newPasswordConfirmation"
        ]
      },
      "ChangePasswordResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Senha alterada com sucesso."
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "LogoutResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Sessão encerrada com sucesso."
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "CreatePeladaBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome da pelada entre 3 e 30 caracteres, sem caracteres especiais.",
            "example": "Pelada Teste 123",
            "minLength": 3,
            "maxLength": 30
          }
        },
        "required": [
          "name"
        ]
      },
      "PeladaDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "d3f6630f-b1e1-450f-a496-d249f0f90e5f"
          },
          "name": {
            "type": "string",
            "example": "Pelada de Sábado"
          },
          "ownerId": {
            "type": "string",
            "example": "c1b4432a-d2e3-4f9e-b123-e456f0f70a1c"
          }
        },
        "required": [
          "id",
          "name",
          "ownerId"
        ]
      },
      "PeladaDataDto": {
        "type": "object",
        "properties": {
          "pelada": {
            "$ref": "#/components/schemas/PeladaDto"
          }
        },
        "required": [
          "pelada"
        ]
      },
      "CreatePeladaResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Pelada criada com sucesso."
          },
          "data": {
            "$ref": "#/components/schemas/PeladaDataDto"
          }
        },
        "required": [
          "success",
          "message",
          "data"
        ]
      },
      "PeladaWithPermissionsDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "d3f6630f-b1e1-450f-a496-d249f0f90e5f"
          },
          "name": {
            "type": "string",
            "example": "Pelada de Sábado"
          },
          "ownerUsername": {
            "type": "string",
            "example": "usuario123"
          },
          "privileges": {
            "type": "array",
            "example": [
              "MANAGE_PLAYERS",
              "DRAW_TEAMS"
            ],
            "items": {
              "type": "string",
              "enum": [
                "MANAGE_PLAYERS",
                "DRAW_TEAMS"
              ]
            }
          }
        },
        "required": [
          "id",
          "name",
          "ownerUsername",
          "privileges"
        ]
      },
      "ListPeladasDataDto": {
        "type": "object",
        "properties": {
          "peladas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PeladaWithPermissionsDto"
            }
          }
        },
        "required": [
          "peladas"
        ]
      },
      "ListPeladasResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Lista de peladas retornada com sucesso."
          },
          "data": {
            "$ref": "#/components/schemas/ListPeladasDataDto"
          }
        },
        "required": [
          "success",
          "message",
          "data"
        ]
      },
      "PlayerSummaryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Messi"
          },
          "stars": {
            "type": "number",
            "example": 10
          },
          "position": {
            "type": "string",
            "enum": [
              "ZAGA",
              "MEIO",
              "ATAQUE",
              "GERAL"
            ],
            "example": "MEIO"
          }
        },
        "required": [
          "name",
          "stars",
          "position"
        ]
      },
      "PeladaWithDetailsDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "d3f6630f-b1e1-450f-a496-d249f0f90e5f"
          },
          "name": {
            "type": "string",
            "example": "Pelada de Sábado"
          },
          "ownerUsername": {
            "type": "string",
            "example": "usuario123"
          },
          "privileges": {
            "type": "array",
            "example": [
              "MANAGE_PLAYERS",
              "DRAW_TEAMS"
            ],
            "items": {
              "type": "string",
              "enum": [
                "MANAGE_PLAYERS",
                "DRAW_TEAMS"
              ]
            }
          },
          "players": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlayerSummaryDto"
            }
          }
        },
        "required": [
          "id",
          "name",
          "ownerUsername",
          "privileges",
          "players"
        ]
      },
      "PeladaDetailsDataDto": {
        "type": "object",
